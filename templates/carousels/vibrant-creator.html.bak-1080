<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=1080">
  <title>{{headline}}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-color: #ff6b35;
      --bg-gradient: linear-gradient(160deg, #ff6b35 0%, #f7c948 100%);
      --text-primary: #1a1a2e;
      --text-secondary: #4a3728;
      --accent-color: #1a1a2e;
      --font-headline: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      --font-body: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      --slide-width: 1080px;
      --slide-height: 1350px;
    }

    body {
      width: var(--slide-width);
      height: var(--slide-height);
      overflow: hidden;
      font-family: var(--font-body);
      background: var(--bg-gradient, var(--bg-color));
      color: var(--text-primary);
      -webkit-font-smoothing: antialiased;
    }

    .slide {
      width: var(--slide-width);
      height: var(--slide-height);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 80px;
      position: relative;
    }

    /* ── Card container ── */
    .card {
      background: #ffffff;
      border-radius: 32px;
      padding: 72px 64px;
      width: 100%;
      max-width: 920px;
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.12),
        0 4px 16px rgba(0, 0, 0, 0.06);
      position: relative;
      z-index: 1;
    }

    /* ── Decorative background shapes ── */
    .deco {
      position: absolute;
      border-radius: 50%;
      z-index: 0;
    }
    .deco-1 {
      top: -40px;
      right: -20px;
      width: 200px;
      height: 200px;
      background: rgba(255, 255, 255, 0.2);
    }
    .deco-2 {
      bottom: 120px;
      left: -30px;
      width: 140px;
      height: 140px;
      background: rgba(255, 255, 255, 0.15);
    }
    .deco-3 {
      top: 35%;
      right: 40px;
      width: 80px;
      height: 80px;
      background: rgba(255, 255, 255, 0.12);
    }

    /* ── COVER ── */
    .slide-cover .card {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .slide-cover .icon {
      font-size: 96px;
      margin-bottom: 32px;
      line-height: 1;
    }
    .slide-cover .headline {
      font-family: var(--font-headline);
      font-size: 64px;
      font-weight: 900;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--text-primary);
    }
    .slide-cover .body {
      font-size: 28px;
      color: var(--text-secondary);
      margin-top: 24px;
      line-height: 1.5;
      max-width: 640px;
    }
    .slide-cover .tag {
      display: inline-block;
      background: var(--bg-color);
      color: #ffffff;
      font-size: 20px;
      font-weight: 700;
      padding: 10px 28px;
      border-radius: 100px;
      margin-top: 36px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* ── CONTENT ── */
    .slide-content .card {
      text-align: left;
    }
    .slide-content .icon {
      font-size: 64px;
      margin-bottom: 24px;
      line-height: 1;
    }
    .slide-content .headline {
      font-family: var(--font-headline);
      font-size: 48px;
      font-weight: 900;
      line-height: 1.12;
      color: var(--text-primary);
      margin-bottom: 20px;
    }
    .slide-content .body {
      font-size: 26px;
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 32px;
    }
    .slide-content .bullets {
      list-style: none;
      padding: 0;
      width: 100%;
    }
    .slide-content .bullets li {
      font-size: 26px;
      color: var(--text-primary);
      padding: 16px 20px;
      background: #f8f9fa;
      border-radius: 16px;
      margin-bottom: 12px;
      line-height: 1.4;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .slide-content .bullets li::before {
      content: "\2714";
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      background: var(--bg-color);
      color: #ffffff;
      border-radius: 10px;
      font-size: 18px;
      flex-shrink: 0;
    }

    /* ── CTA ── */
    .slide-cta .card {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .slide-cta .icon {
      font-size: 80px;
      margin-bottom: 28px;
      line-height: 1;
    }
    .slide-cta .headline {
      font-family: var(--font-headline);
      font-size: 56px;
      font-weight: 900;
      line-height: 1.1;
      color: var(--text-primary);
      margin-bottom: 24px;
    }
    .slide-cta .body {
      font-size: 26px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-bottom: 40px;
      max-width: 580px;
    }
    .slide-cta .cta-button {
      display: inline-block;
      padding: 28px 72px;
      background: var(--accent-color);
      color: #ffffff;
      font-size: 28px;
      font-weight: 800;
      text-decoration: none;
      border-radius: 100px;
      box-shadow: 0 8px 24px rgba(26, 26, 46, 0.25);
    }

    /* ── BOTTOM BAR ── */
    .bottom-bar {
      position: absolute;
      bottom: 28px;
      left: 80px;
      right: 80px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 2;
    }
    .brand-handle {
      font-size: 22px;
      color: rgba(255, 255, 255, 0.85);
      font-weight: 700;
    }
    .progress {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .progress-dots {
      display: flex;
      gap: 8px;
    }
    .progress-dots .dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.35);
    }
    .progress-dots .dot.active {
      background: #ffffff;
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
    }
    .slide-counter {
      font-size: 20px;
      color: rgba(255, 255, 255, 0.85);
      font-weight: 700;
    }
  </style>
</head>
<body>

  <!-- COVER variant -->
  <div class="slide slide-cover">
    <div class="deco deco-1"></div>
    <div class="deco deco-2"></div>
    <div class="deco deco-3"></div>
    <div class="card">
      <div class="icon">{{icon}}</div>
      <h1 class="headline">{{headline}}</h1>
      <p class="body">{{body}}</p>
      <span class="tag">{{brand_name}}</span>
    </div>
    <div class="bottom-bar">
      <span class="brand-handle">{{brand_handle}}</span>
      <div class="progress">
        <div class="progress-dots">{{progress_dots}}</div>
        <span class="slide-counter">{{slide_number}}/{{total_slides}}</span>
      </div>
    </div>
  </div>

  <!-- CONTENT variant -->
  <!--
  <div class="slide slide-content">
    <div class="deco deco-1"></div>
    <div class="deco deco-2"></div>
    <div class="deco deco-3"></div>
    <div class="card">
      <div class="icon">{{icon}}</div>
      <h2 class="headline">{{headline}}</h2>
      <p class="body">{{body}}</p>
      <ul class="bullets">{{bullets}}</ul>
    </div>
    <div class="bottom-bar">
      <span class="brand-handle">{{brand_handle}}</span>
      <div class="progress">
        <div class="progress-dots">{{progress_dots}}</div>
        <span class="slide-counter">{{slide_number}}/{{total_slides}}</span>
      </div>
    </div>
  </div>
  -->

  <!-- CTA variant -->
  <!--
  <div class="slide slide-cta">
    <div class="deco deco-1"></div>
    <div class="deco deco-2"></div>
    <div class="deco deco-3"></div>
    <div class="card">
      <div class="icon">{{icon}}</div>
      <h2 class="headline">{{headline}}</h2>
      <p class="body">{{body}}</p>
      <a href="{{cta_action}}" class="cta-button">{{cta_text}}</a>
    </div>
    <div class="bottom-bar">
      <span class="brand-handle">{{brand_handle}}</span>
      <div class="progress">
        <div class="progress-dots">{{progress_dots}}</div>
        <span class="slide-counter">{{slide_number}}/{{total_slides}}</span>
      </div>
    </div>
  </div>
  -->

</body>
</html>
