# ──────────────────────────────────────────────────────────────
# GrowthOS .gitignore
#
# Philosophy:
#   - Keep folder STRUCTURE (so any project works out of the box)
#   - Ignore CONTENT that is personal or unique per project
#     (brand voice, design system, assets, outputs)
#   - Empty folders are preserved via .gitkeep files
# ──────────────────────────────────────────────────────────────

# ── Secrets & environment ─────────────────────────────────────
.env
.env.*
!.env.example
!.env.production.example
*.key
*.pem
*.secret

# ── Personal brand voice config ───────────────────────────────
brand-voice.yaml
!brand-voice.example.yaml

# ── Personal content: voice/ (brand voice, golden docs, etc.) ─
# Keep folder structure, ignore everything else.
voice/**
!voice/
!voice/**/
!voice/.gitkeep
!voice/**/.gitkeep
!voice/README.md

# ── Personal content: design-system/ ──────────────────────────
design-system/**
!design-system/
!design-system/**/
!design-system/.gitkeep
!design-system/**/.gitkeep
!design-system/README.md

# ── Personal content: assets/ (logos, photos, screenshots…) ───
assets/**
!assets/
!assets/**/
!assets/.gitkeep
!assets/**/.gitkeep
!assets/README.md

# ── Runtime outputs (per-project content) ─────────────────────
output/approved/**
output/carousels/**
output/exports/**
output/revisions/**
output/reviews/**
out/**
!output/**/.gitkeep
!out/.gitkeep

# ── GrowthOS runtime artifacts ────────────────────────────────
.growthOS/
.growthos/

# ── Playwright (browser automation artifacts & sessions) ──────
.playwright/
playwright-report/
playwright/.cache/
playwright/.auth/
test-results/
storage-state.json
.auth.json
chrome-profile/
**/chrome-profile/
*.webm
*.har
trace.zip

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Epic executor / misc tooling ──────────────────────────────
.epic-executor/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
