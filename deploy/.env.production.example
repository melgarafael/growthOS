# ──────────────────────────────────────────────────────────
# GrowthOS Production Environment
# Copy to .env.production and fill in your values
# ──────────────────────────────────────────────────────────

# ─── Domain & SSL ─────────────────────────────────────────
DOMAIN=app.example.com
ADMIN_EMAIL=admin@example.com

# ─── Dashboard Auth ───────────────────────────────────────
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
DASHBOARD_USER=admin
DASHBOARD_HASH=

# ─── Social Publishing API Keys ──────────────────────────
GROWTHOS_TWITTER_API_KEY=
GROWTHOS_TWITTER_API_SECRET=
GROWTHOS_TWITTER_ACCESS_TOKEN=
GROWTHOS_TWITTER_ACCESS_SECRET=

GROWTHOS_LINKEDIN_TOKEN=
GROWTHOS_LINKEDIN_ORG_ID=

GROWTHOS_REDDIT_CLIENT_ID=
GROWTHOS_REDDIT_CLIENT_SECRET=
GROWTHOS_REDDIT_USERNAME=
GROWTHOS_REDDIT_PASSWORD=

GROWTHOS_GITHUB_TOKEN=
GROWTHOS_THREADS_TOKEN=

# ─── Obsidian Vault ──────────────────────────────────────
GROWTHOS_VAULT_PATH=../vault

# ─── Plugin Configuration ────────────────────────────────
GROWTHOS_BRAND_VOICE_PATH=./brand-voice.yaml
GROWTHOS_CONFIG_DIR=.
GROWTHOS_AUDIT_DIR=.growthOS/audit

# ─── Autonomy & Safety ──────────────────────────────────
GROWTHOS_AUTONOMY_LEVEL=supervised
GROWTHOS_DRY_RUN=false

# ─── MCP Server Ports (internal only) ───────────────────
GROWTHOS_PUBLISH_PORT=8001
GROWTHOS_DISCOVER_PORT=8002
GROWTHOS_VAULT_PORT=8003

# ─── Notifications ──────────────────────────────────────
# Discord or Slack webhook for deploy/health alerts
GROWTHOS_WEBHOOK_URL=

# ─── Docker Images (GHCR) ────────────────────────────────
# Set these if pulling pre-built images from GitHub Container Registry
# Leave empty to build locally
GHCR_PREFIX=
IMAGE_TAG=latest

# ─── Backup ─────────────────────────────────────────────
GROWTHOS_BACKUP_DIR=/var/backups/growthos
